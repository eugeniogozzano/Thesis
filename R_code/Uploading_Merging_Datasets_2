library(tidyr)
library(zoo) 

dataset_imputed <- dataset_summer %>%
  arrange(iso_code_mapped, year) %>%
  group_by(iso_code_mapped) %>%
  # A. First pass: Linearly interpolate internal gaps (e.g., between 2000 and 2016)
  mutate(
    GDP_merged = na.approx(GDP_merged, na.rm = FALSE),
    population = na.approx(population, na.rm = FALSE),
    perc_athletic_prime = na.approx(perc_athletic_prime, na.rm = FALSE)
  ) %>%
  # B. Second pass: Use 'fill' as a dataframe verb to carry edge-case data forward AND backward
  # This grabs the 2000 data and pulls it back to 1996 for NZL and BRA
  fill(GDP_merged, population, perc_athletic_prime, .direction = "downup") %>%
  ungroup()

# Check if it worked
missing_after_imputation <- dataset_imputed %>%
  filter(!is.na(Total) & Total > 0) %>%
  filter(is.na(GDP_merged))

if(nrow(missing_after_imputation) > 0) {
  message("These countries STILL have no economic data (they likely have no data in your dataset at all):")
  print(unique(missing_after_imputation$iso_code_mapped))
} else {
  message("SUCCESS: All economic data has been interpolated and filled. You are ready for Python.")
}
#############################################################################################################


#Adding the columns Weighted_SCore, Prev_Total_Score, etc etc
dataset_final <- dataset_imputed %>%
  # 1. FORCE ALL ROWS TO EXIST (This must happen first!)
  complete(
    iso_code_mapped, 
    year = summer_years, 
    fill = list(Gold = 0, Silver = 0, Bronze = 0, Total = 0)
  ) %>%
  
  # 2. IMPUTE ECONOMIC DATA 
  arrange(iso_code_mapped, year) %>%
  group_by(iso_code_mapped) %>%
  mutate(
    GDP_merged = na.approx(GDP_merged, na.rm = FALSE),
    population = na.approx(population, na.rm = FALSE),
    perc_athletic_prime = na.approx(perc_athletic_prime, na.rm = FALSE)
  ) %>%
  # This will now successfully grab the 2000 data and push it backward to the newly created 1996/1992 rows!
  fill(GDP_merged, population, perc_athletic_prime, .direction = "downup") %>%
  
  # 3. CALCULATE HOST AND LAG VARIABLES
  mutate(
    Weighted_Score = (Gold * 3) + (Silver * 2) + (Bronze * 1),
    
    Is_Host = case_when(
      iso_code_mapped == "ESP" & year == 1992 ~ 1,
      iso_code_mapped == "USA" & year == 1996 ~ 1,
      iso_code_mapped == "AUS" & year == 2000 ~ 1,
      iso_code_mapped == "GRC" & year == 2004 ~ 1,
      iso_code_mapped == "CHN" & year == 2008 ~ 1,
      iso_code_mapped == "GBR" & year == 2012 ~ 1,
      iso_code_mapped == "BRA" & year == 2016 ~ 1,
      iso_code_mapped == "JPN" & year == 2021 ~ 1,
      iso_code_mapped == "FRA" & year == 2024 ~ 1,
      TRUE ~ 0
    ),
    
    Prev_Total_Medals = lag(Total, n = 1),
    Prev_Weighted_Score = lag(Weighted_Score, n = 1)
  ) %>%
  ungroup() %>%
  
  # 4. OVERWRITE MISSING LAGS FOR THE 1992 BASELINE
  mutate(
    Prev_Total_Medals = ifelse(is.na(Prev_Total_Medals), 0, Prev_Total_Medals),
    Prev_Weighted_Score = ifelse(is.na(Prev_Weighted_Score), 0, Prev_Weighted_Score)
  )

