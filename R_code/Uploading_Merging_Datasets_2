prime_age = read.csv("WPP2024_PopulationByAge5GroupSex_Percentage_Medium.csv")
prime_age_92 =  prime_age |> 
  select(-c( LocID, Location, Variant, VarID, Notes, SDMX_code)) |> 
  filter(Time >= 1992) 
  



# 3. Calculate the correct percentage
prime_percentage <- prime_age_92 %>%
  # Remove rows with empty/missing ISO codes (like the global/regional aggregates)
  filter(!is.na(ISO3_code) & ISO3_code != "") %>%
  
  # Filter for the "athletic prime" age brackets
  filter(AgeGrp %in% c("15-19", "20-24", "25-29", "30-34", "35-39")) %>%
  
  # Group by country and year
  group_by(ISO3_code, Time) %>%
  
  # Because PopTotal is already a percentage, just adding them together gives you the final %
  summarise(perc_athletic_prime = sum(PopTotal, na.rm = TRUE), .groups = "drop") %>%
  
  # Rename columns to match your main thesis dataset exactly
  rename(iso_code_mapped = ISO3_code, year = Time)

# 4. Merge this back into your main dataset
df_after_prime_age <- df_pop %>%
  left_join(prime_percentage, by = c("iso_code_mapped", "year"))



# 6. Save the perfectly complete dataset
write.csv(df_after_prime_age, "dataset_thesis_1992_after_prime_age_v4.csv", row.names = FALSE)

